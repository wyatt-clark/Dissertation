@article{Kuzniar2008,
	Abstract = {Orthology is a key evolutionary concept in many areas of genomic research. It provides a framework for subjects as diverse as the evolution of genomes, gene functions, cellular networks and functional genome annotation. Although orthologous proteins usually perform equivalent functions in different species, establishing true orthologous relationships requires a phylogenetic approach, which combines both trees and graphs (networks) using reliable species phylogeny and available genomic data from more than two species, and an insight into the processes of molecular evolution. Here, we evaluate the available bioinformatics tools and provide a set of guidelines to aid researchers in choosing the most appropriate tool for any situation.},
	Annote = {Kuzniar, Arnold van Ham, Roeland C. H. J. Pongor, Sandor Leunissen, Jack A. M.},
	Author = {Kuzniar, A and van Ham, Rchj and Pongor, S and Leunissen, J A M},
